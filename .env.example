# ===== 环境变量说明 =====
# 复制此文件为 .env（本地开发用），不要提交 .env 到 Git

# Vercel Postgres 自动注入 POSTGRES_URL，Railway/本地开发用 DATABASE_URL
# 二者只需设置一个，代码优先读取 POSTGRES_URL
POSTGRES_URL=postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@localhost:5432/magazine_studio

# 管理后台密码（自定义，不要使用弱密码）
ADMIN_PASSWORD=your_admin_password_here

# Resend 邮件服务（https://resend.com）
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
# 发件人地址，需在 Resend 后台验证域名后才能自定义；未配置则使用默认值
RESEND_FROM=about编辑部 <noreply@yourdomain.com>

# 运行环境：development 或 production
# Railway 会自动设为 production
NODE_ENV=development

# 服务端口，Railway 会自动注入
PORT=3000
